---
interface Props {
  message?: string;
  hint?: string;
  showHideCheckedControl?: boolean;
}

const {
  message = 'Loading recommendations...',
  hint,
  showHideCheckedControl = true,
} = Astro.props;
---

<div class="space-y-3" aria-busy="true">
  <section class="rounded-2xl border border-slate-200 bg-slate-50/70 p-2.5 sm:p-3">
    <div class="grid gap-2.5">
      <div class="space-y-1.5">
        <p class="text-[0.68rem] font-sans font-semibold uppercase tracking-[0.18em] text-slate-500">
          Reading Type
        </p>
        <div class="grid grid-cols-2 gap-1.5 xl:grid-cols-4">
          {Array.from({ length: 4 }).map((_, index) => (
            <div
              class={`min-h-9 rounded-full border px-2.5 py-1.5 ${
                index === 0
                  ? 'border-slate-300 bg-white shadow-sm shadow-slate-200/70'
                  : 'border-slate-200/70 bg-slate-50/60'
              }`}
            >
              <div class={`h-2 rounded-full ${index === 0 ? 'bg-slate-300' : 'bg-slate-200'}`} style={`width:${index === 0 ? '60%' : '52%'}`} />
            </div>
          ))}
        </div>
      </div>
    </div>
    {showHideCheckedControl ? (
      <div class="mt-2 flex flex-wrap items-center gap-2 border-t border-slate-200/80 px-0.5 pt-2 text-xs">
        <div class="h-8 w-28 rounded-full border border-slate-200 bg-white/85" />
      </div>
    ) : null}
  </section>

  <section class="rounded-2xl border border-amber-200 bg-amber-50/70 p-4 sm:p-5">
    <div class="space-y-2">
      <div class="h-3.5 w-32 rounded-full bg-amber-200/80" />
      <p class="text-sm text-amber-900/80">{message}</p>
      {hint ? (
        <p class="text-xs leading-5 text-amber-900/70">{hint}</p>
      ) : null}
    </div>

    <div class="mt-4 rounded-xl border border-amber-200 bg-white p-4">
      <div class="h-5 w-3/4 rounded bg-slate-200/80" />
      <div class="mt-2 h-3 w-1/3 rounded bg-slate-100" />
      <div class="mt-4 flex items-center gap-2">
        <div class="h-1.5 flex-1 rounded-full bg-slate-100" />
        <div class="h-3 w-20 rounded bg-slate-100" />
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <div class="h-6 w-24 rounded-full bg-amber-100" />
        <div class="h-6 w-28 rounded-full bg-slate-100" />
        <div class="h-6 w-32 rounded-full bg-slate-100" />
      </div>
      <div class="mt-4 h-10 rounded-xl border border-slate-200 bg-slate-50/70" />
    </div>
  </section>
</div>
