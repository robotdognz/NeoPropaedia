        {
          "level": "3",
          "levelType": "numeric",
          "text": "Types of educational systems and their characteristics",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Centralized systems: systems in which control is exercised through a national administrative agency",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Decentralized systems: systems in which control is exercised at the regional or local level",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Joint national and local systems",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Systems controlled by political parties",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Sectarian systems: national and regional sectarian systems, sectarian education as an alternative system to public education",
              "children": []
            }
          ]
        }
      ]
    },
