      ]
    },
    {
      "level": "D",
      "levelType": "major",
      "text": "Rail transportation",
      "children": []
    },
    {
      "level": "E",
      "levelType": "major",
      "text": "Stationary conveyance systems; e.g., pipelines, conveyor belts [see 725.C.2.]",
      "children": []
