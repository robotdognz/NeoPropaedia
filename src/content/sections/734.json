  "title": "Transportation Technology",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "History of transportation",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Primitive transportation; e.g., travois, slide car, sledge, pack animal, dugout",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "The wheel and the road: development of the vehicle wheel, roads of the ancient world, beginnings of the modern road",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Sails and oars: beginnings of shipping and shipbuilding, growth of inland waterways",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Steam transportation",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "The railroad: the first locomotives, the spread of railways, the construction of railroad bridges and tunnels",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Steam navigation: the first steamships, introduction of iron ships, decline of sailing fleets",
              "children": []
            }
          ]
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Development of modern transportation",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Construction of road vehicles, roads, bridges, and tunnels",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Development of mass urban transport and traffic networks",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Development of the air transport industry",
              "children": []
            }
          ]
        }
      ]
    },
    {
      "level": "B",
      "levelType": "major",
      "text": "Roads and highways and their construction",
      "children": []
    },
    {
