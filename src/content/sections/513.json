{
  "sectionCode": "513",
  "sectionCodeDisplay": "513",
  "title": "Major Cultural Components and Institutions of Human Societies",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "Systems of relationship based upon marriage and descent: kinship",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "General aspects of kinship",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Laws and customs regarding mate selection, sexual behaviour, marriage and divorce, legitimacy [see also 553. B.)",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Rules of residence; e.g., virilocal, uxorilocal, neolocal",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Descent systems: unilineal, cognatic, and variant forms",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Control of resources, inheritance, and succession: the family as a centre for transmission of economic, religious, political, and other powers and goods",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "Kinship and social change: kinship as an evolving social institution",
          "children": []
        }
      ]
    },
    {
      "level": "B",
      "levelType": "major",
      "text": "Other social structures",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "The varieties of groups and other associations within societies",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Organization by status: class systems, caste systems, systems characterized by slavery or serfdom",
          "children": []
        }
      ]
    },
    {
      "level": "C",
      "levelType": "major",
      "text": "Types of economic systems",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "The economic systems of primitive or nonurban peoples",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Production, division of labour, role differentiation",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Exchange of goods, distribution of wealth",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Property and property rights",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "The economic systems of developed nations [see Division III, below]",
          "children": []
        }
      ]
    },
    {
      "level": "D",
      "levelType": "major",
      "text": "Other elements common to all cultures but differing in expression or practice between cultures",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Education and socialization: formal and informal enculturation",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Religious belief, folklore [for religious belief, see 811]",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Legal systems [see 551. B.]",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Artistic expression: literature, visual arts, performing arts; crafts [see 611, 612, and 613]",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Linguistic systems [see 514]",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "Recreation, sports and games",
          "children": []
        }
      ]
    }
  ],
