  "title": "Physical Features of the Earth’s Surface",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "Vertical relief of the Earth's surface",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "FLypsography of the Earth's surface: distribution of land and sea, elevation of the continents, coastlines",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Physiography of the continents: Europe, Asia, Africa, Australia, North America, South America, Antarctica",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "The oceanic regions",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Principal oceanic features: continental margins, oceanic ridges, deep-sea trenches, and abyssal hills and plains [see C., D., and G., below, and 723.G.3.]",
