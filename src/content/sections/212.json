{
  "sectionCode": "212",
  "sectionCodeDisplay": "212",
  "title": "The Earth’s Physical Properties",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "The Earth's gravitational field [see also 131.B.]",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Characteristics of the terrestrial field",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Measurement of gravitational acceleration [see also 723.D.2.d.]",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Interpretation of gravity data: inferences about the Earth's interior",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Isostasy: the approximate balance between the elevation of the Earth's surface and the density of the rocks below",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Gravity anomalies",
              "children": []
            }
          ]
        }
      ]
    },
    {
      "level": "B",
      "levelType": "major",
      "text": "The Earth's magnetic field",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Measurement and representation of magnetic fields",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Sources and characteristics of the Earth's main magnetic field",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Variations in the main magnetic field, including polarity reversals, magnetic storms, magnetospheric substorms, and magnetic pulsations",
          "children": []
        }
      ]
    },
    {
      "level": "C",
      "levelType": "major",
      "text": "The Earth's electrical properties [see also 127. B.]",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Currents produced by the motion of charged particles in the Earth's ionosphere [see also 221.A.3.b]",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Electrical conductivity and dielectric behaviour of the Earth's rocks and minerals",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Currents induced by magnetic-field variations, currents generated by the Earth's core",
          "children": []
        }
      ]
    },
    {
      "level": "D",
      "levelType": "major",
      "text": "The Earth's thermal properties [see also 124.A.4.C.]",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Sources of the Earth's heat [see also 112.C. 5.]",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Transmission of heat from the Earth's interior to its surface: thermal conductivity and gradients, heat flow data",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Geologic aspects of heat flow: convection currents within the Earth, rock metamorphism, and mountain building",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Surface manifestations of heat flow: volcanoes, hot springs, geysers, and related phenomena",
          "children": []
        }
      ]
    },
    {
      "level": "E",
      "levelType": "major",
      "text": "The mechanical properties of the Earth",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "The fundamental mechanical properties of the Earth's body and the indirect evidence used to determine them",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Nature of deformable media: stress and strain, models of the stress-strain behaviour of materials, seismic waves [see also 126.D.]",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "The basic internal mechanical properties of the Earth",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "The Earth's departures from spherical symmetry: oblateness, lateral variations associated with crustal structure, isostasy and its effects [see also 21 l.A.2.b.]",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Anelasticity in the Earth",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "Response of the Earth to stresses of long duration",
          "children": []
        }
      ]
    },
    {
      "level": "F",
      "levelType": "major",
      "text": "Physical properties of Earth materials",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Volumetric properties: rock density and porosity",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Mechanical properties [see also 126.D., E., and G.]",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Thermal properties: specific heat and thermal conductivity, thermal expansion and rock melting",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Magnetic and electrical properties [see also C.2., above]",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Hydraulic properties: porosity and permeability, the capacity to store and transmit fluids",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "Optical properties: colour, lustre",
          "children": []
        }
      ]
    },
    {
      "level": "G",
      "levelType": "major",
      "text": "The deformation of materials in the Earth's crust",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Stress and strain of rocks",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Response to stress",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Elastic and plastic deformation",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Folding of rocks",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Tectonic folding",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Foliation, lineation",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Nappes (large rock sheets thrust over other rock formations)",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Salt domes and other diapiric structures [see also 724.B. 1 .b.]",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Nontectonic folding; e.g., slumping of recently deposited sediments",
              "children": []
            }
          ]
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Fracture in rocks: joints, faults",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Structural interference: the superposition of strains produced by the tectonic events of different ages",
          "children": []
        }
      ]
    }
  ],
