---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import MacropaediaLibrary from '../../components/content/MacropaediaLibrary';
import { getCollection } from 'astro:content';
import { buildMacropaediaAggregateEntries } from '../../utils/readingData';

const base = import.meta.env.BASE_URL;
const sections = await getCollection('sections');

const entries = buildMacropaediaAggregateEntries(sections.map((entry) => entry.data));
---

<BaseLayout
  title="Macropaedia Library — Propaedia"
  description="Browse the full Macropaedia article list referenced in the Propaedia outline, with section counts and shared checklist state."
>
  <main id="main-content" class="mx-auto w-full max-w-screen-2xl px-4 py-8 sm:px-6 lg:px-8">
    <header class="max-w-4xl">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-gray-500">Reading Lists</p>
      <h1 class="mt-3 font-serif text-4xl text-gray-900 sm:text-5xl">Macropaedia Articles</h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg">
        Search the full historical Macropaedia reading list from the outline, sort by how widely each article appears,
        and keep the same checklist state you use on section pages.
      </p>
    </header>

    <section class="mt-10">
      <MacropaediaLibrary client:load entries={entries} baseUrl={base} />
    </section>
  </main>
</BaseLayout>
